# Local: bolt://localhost:7687
# AuraDB: neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me

# Optional API protection
APP_API_KEY=
RATE_LIMIT_PER_MINUTE=120

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false

# Gemini
GEMINI_KEY_FILE=.gemini_key.txt
GEMINI_MODEL_TEXT=gemini-2.0-flash
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
REQUIRE_GEMINI_KEY_ON_STARTUP=false

# Embeddings backend (gemini or local)
EMBEDDING_BACKEND=gemini
LOCAL_EMBEDDING_MODEL=GreenNode/GreenNode-Embedding-Large-VN-Mixed-V1
EMBEDDING_DIM=1024

# NER backend (simple, underthesea, or phonlp)
NER_BACKEND=simple
PHONLP_MODEL_DIR=.phonlp
VNCORENLP_DIR=.vncorenlp

# Model mode (api = Gemini, local = Vi-Qwen2-7B-RAG)
MODEL_MODE=api
LOCAL_MODEL_ID=AITeamVN/Vi-Qwen2-7B-RAG

# Neo4j Cypher 25 SEARCH clause (requires Neo4j 2026.02+)
NEO4J_USE_SEARCH_CLAUSE=false

# LoRA adapter for fine-tuned Text2Cypher (optional)
LORA_ADAPTER_PATH=
